# Copy this file to ".env" (same folder) and paste your key. Never commit .env.
GEMINI_API_KEY=paste-your-google-ai-studio-key-here
# Optional — defaults to gemini-2.5-flash
# GEMINI_MODEL=gemini-2.5-flash

# --- Payments (optional) — real billing via Paystack; demo upgrade if blank ---
# Get a TEST secret key at dashboard.paystack.com (starts with sk_test_)
PAYSTACK_SECRET_KEY=
# PRO_PRICE_KOBO=250000        # ₦2,500 (amount is in kobo)

# --- Email (optional) — password reset via Resend; shows link on-screen if blank ---
# Free key at resend.com. MAIL_FROM must be a verified sender (or use the test one).
RESEND_API_KEY=
# MAIL_FROM=Nova <onboarding@resend.dev>
